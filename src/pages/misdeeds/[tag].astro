---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { labelFor, severityLabels, statusLabels, tagLabels } from "../../data/labels.js";

export function getStaticPaths() {
  const caseModules = import.meta.glob("../cases/*.md", { eager: true });
  const allCases = Object.values(caseModules)
    .map((entry) => ({
      ...entry.frontmatter,
      url: entry.url.endsWith("/") ? entry.url : `${entry.url}/`
    }))
    .sort((a, b) => String(b.date).localeCompare(String(a.date)));
  const allTags = [...new Set(allCases.flatMap((entry) => entry.tags ?? []))];

  return allTags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      cases: allCases.filter((entry) => (entry.tags ?? []).includes(tag))
    }
  }));
}

const { tag, cases } = Astro.props;
const tagLabel = labelFor(tagLabels, tag);
---

<BaseLayout title={`${tagLabel} | 狗日的应用`}>
  <header class="page-head">
    <a class="back-link" href="/misdeeds/">返回恶行</a>
    <h1>{tagLabel}</h1>
  </header>

  <div class="article-list">
    {cases.map((entry) => (
      <article class="article-row">
        <h3><a href={entry.url}>{entry.title}</a></h3>
        <div class="row-meta">
          <a href={`/companies/${entry.companySlug}/`}>{entry.company}</a>
          <span class="badge amber">{labelFor(statusLabels, entry.status)}</span>
          <span class="badge danger">{labelFor(severityLabels, entry.severity)}</span>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>

