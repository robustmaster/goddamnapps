---
import BaseLayout from "../layouts/BaseLayout.astro";
import { labelFor, tagLabels } from "../data/labels.js";

const caseModules = import.meta.glob("./cases/*.md", { eager: true });
const cases = Object.values(caseModules)
  .map((entry) => ({
    ...entry.frontmatter,
    url: entry.url.endsWith("/") ? entry.url : `${entry.url}/`
  }))
  .sort((a, b) => String(b.date).localeCompare(String(a.date)));

const allTags = [...new Set(cases.flatMap((entry) => entry.tags ?? []))].sort();
---

<BaseLayout>
  <header class="page-head">
    <h1>狗日的应用</h1>
  </header>

  <section aria-labelledby="tags-heading">
    <div class="section-head">
      <h2 id="tags-heading">标签</h2>
    </div>
    <div class="tag-list">
      {allTags.map((tag) => <a class="pill" href={`/misdeeds/${tag}/`}>{labelFor(tagLabels, tag)}</a>)}
    </div>
  </section>

  <section aria-labelledby="latest-heading">
    <div class="section-head">
      <h2 id="latest-heading">文章</h2>
    </div>

    {cases.length === 0 ? (
      <p class="empty">还没有记录。</p>
    ) : (
      <div class="article-list">
        {cases.map((entry) => (
          <article class="article-row">
            <h3><a href={entry.url}>{entry.title}</a></h3>
            <div class="row-meta">
              <a href={`/companies/${entry.companySlug}/`}>{entry.company}</a>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
