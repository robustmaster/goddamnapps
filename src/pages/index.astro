---
import BaseLayout from "../layouts/BaseLayout.astro";

const caseModules = import.meta.glob("./cases/*.md", { eager: true });
const cases = Object.values(caseModules)
  .map((entry) => ({
    ...entry.frontmatter,
    url: entry.url.endsWith("/") ? entry.url : `${entry.url}/`
  }))
  .sort((a, b) => String(b.date).localeCompare(String(a.date)));

const allTags = [...new Set(cases.flatMap((entry) => entry.tags ?? []))].sort();
---

<BaseLayout>
  <section class="hero">
    <div>
      <p class="eyebrow">Consumer harm, minus the corporate poetry.</p>
      <h1>Apps that screw users, documented with receipts.</h1>
      <p class="hero-copy">
        Goddamn Apps is a small public notebook for privacy abuse, dark patterns,
        malware-like behavior, refund hell, and other user-hostile software.
      </p>
    </div>
    <aside class="callout">
      <strong>Got receipts?</strong>
      <p>
        Send source links, screenshots, version numbers, and reproduction notes to
        <a href="mailto:tips@goddamnapps.com">tips@goddamnapps.com</a>.
      </p>
    </aside>
  </section>

  <section aria-labelledby="tags-heading">
    <div class="section-head">
      <h2 id="tags-heading">Tags</h2>
    </div>
    <div class="tag-list">
      {allTags.map((tag) => <a class="pill" href={`/tags/${tag}/`}>{tag}</a>)}
    </div>
  </section>

  <section aria-labelledby="latest-heading">
    <div class="section-head">
      <h2 id="latest-heading">Latest cases</h2>
    </div>

    {cases.length === 0 ? (
      <p class="empty">No cases yet.</p>
    ) : (
      <div class="case-grid">
        {cases.map((entry) => (
          <article class="case-card">
            <p class="eyebrow">{entry.company}</p>
            <h3><a href={entry.url}>{entry.title}</a></h3>
            <p>{entry.summary}</p>
            <div class="case-meta">
              <span class="badge amber">{entry.status}</span>
              <span class="badge danger">{entry.severity}</span>
              {(entry.tags ?? []).map((tag) => <span class="badge teal">{tag}</span>)}
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
