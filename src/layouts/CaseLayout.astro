---
import BaseLayout from "./BaseLayout.astro";
import { labelFor, severityLabels, statusLabels, tagLabels } from "../data/labels.js";

const { frontmatter } = Astro.props;
const tags = frontmatter.tags ?? [];
const sourceLinks = frontmatter.sources ?? [];
const pageTitle = `${frontmatter.title} | Goddamn Apps`;
---

<BaseLayout title={pageTitle} description={frontmatter.summary}>
  <article class="case-page">
    <a class="back-link" href="/">返回案例</a>
    <header class="case-hero">
      <p class="eyebrow">{frontmatter.company}</p>
      <h1>{frontmatter.title}</h1>
      <p class="summary">{frontmatter.summary}</p>

      <dl>
        <div class="fact-row">
          <dt>应用</dt>
          <dd>{frontmatter.app}</dd>
        </div>
        <div class="fact-row">
          <dt>状态</dt>
          <dd><span class="badge amber">{labelFor(statusLabels, frontmatter.status)}</span></dd>
        </div>
        <div class="fact-row">
          <dt>恶劣程度</dt>
          <dd><span class="badge danger">{labelFor(severityLabels, frontmatter.severity)}</span></dd>
        </div>
        <div class="fact-row">
          <dt>标签</dt>
          <dd class="mini-meta">
            {tags.map((tag) => <a class="badge teal" href={`/tags/${tag}/`}>{labelFor(tagLabels, tag)}</a>)}
          </dd>
        </div>
        <div class="fact-row">
          <dt>最后更新</dt>
          <dd>{frontmatter.date}</dd>
        </div>
      </dl>
    </header>

    <div class="prose">
      <slot />

      {sourceLinks.length > 0 && (
        <>
          <h2>证据</h2>
          <ul class="source-list">
            {sourceLinks.map((source) => (
              <li>
                <a class="source-link" href={source.url} rel="noreferrer" target="_blank">
                  {source.label}
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </div>
  </article>
</BaseLayout>
